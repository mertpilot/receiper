APP_NAME=Receiper Cloud
APP_ENV=development
DATABASE_URL=postgresql+psycopg2://receiper:receiper123@localhost:5432/receiper
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
UPLOAD_ROOT=data/uploads
MAX_UPLOAD_MB=10
PAIRING_TTL_MINUTES=5
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
DASHBOARD_BASE_URL=http://localhost:8000
OCR_LANG=tur+eng
TESSERACT_CMD=/usr/bin/tesseract
TESSDATA_PREFIX=/usr/share/tesseract-ocr/5/tessdata
OCR_TESSERACT_TIMEOUT_SECONDS=8
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_FALLBACK_ENABLED=true
GEMINI_TIMEOUT_SECONDS=6
